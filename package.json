{
  "name": "pyxyflow",
  "version": "0.1.0",
  "private": true,
  "description": "Maintainer-side build for the pyxyflow front-end bundle (not published to npm).",
  "type": "module",
  "scripts": {
    "build": "esbuild js/index.js --bundle --format=esm --minify --loader:.css=text --outfile=src/pyxyflow/static/widget.js",
    "dev": "esbuild js/index.js --bundle --format=esm --sourcemap --loader:.css=text --outfile=src/pyxyflow/static/widget.js --watch"
  },
  "dependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
