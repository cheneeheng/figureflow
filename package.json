{
  "name": "figureflow",
  "version": "0.1.0",
  "private": true,
  "description": "Maintainer-side front-end build for figureflow (esbuild bundle).",
  "type": "module",
  "scripts": {
    "build": "esbuild js/index.js --bundle --format=esm --minify --loader:.css=text --outfile=src/figureflow/static/widget.js",
    "dev": "esbuild js/index.js --bundle --format=esm --loader:.css=text --sourcemap --watch --outfile=src/figureflow/static/widget.js"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
